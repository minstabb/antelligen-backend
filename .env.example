# ─────────────────────────────────────────
# Antelligen Backend — 환경변수 템플릿
# ─────────────────────────────────────────
# 사용법: 이 파일을 `.env` 로 복사 후 실제 값을 채워 사용하세요.
# 기본값이 있는 항목은 주석 처리되어 있으며, 필요 시 풀어서 override.
# 비밀(secret)이 포함된 항목은 절대 커밋하지 마세요. `.env` 는 .gitignore 에 등록되어 있습니다.

# ─────────────────────────────────────────
# 환경 (local | production)
# ─────────────────────────────────────────
ENV=local

# ─────────────────────────────────────────
# PostgreSQL (필수)
# ─────────────────────────────────────────
POSTGRES_USER=root
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=multi_agent_db

# ─────────────────────────────────────────
# Redis (선택, 기본 localhost:6379)
# ─────────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─────────────────────────────────────────
# 인증 / OAuth (필수)
# ─────────────────────────────────────────
# 32자 이상 임의 문자열. `openssl rand -hex 32` 권장
JWT_SECRET_KEY=change-this-to-a-secure-random-secret
# 데모/스크립트용 자동 로그인 비밀번호 (운영 환경에선 빈 문자열 권장)
AUTH_PASSWORD=

KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_REDIRECT_URI=http://localhost:33333/api/v1/kakao-authentication/request-access-token-after-redirection

# 네이버 검색 API (뉴스 수집용)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ─────────────────────────────────────────
# 외부 API 키 (필수/선택)
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
# Anthropic 사용 안 하면 빈 문자열 또는 0 가능
ANTHROPIC_API_KEY=

# 선택: SerpAPI (Google 검색)
SERP_API_KEY=
# 선택: DART 한국 공시
OPEN_DART_API_KEY=
# 선택: YouTube Data API
YOUTUBE_API_KEY=
# 선택: FRED 거시경제 시리즈
FRED_API_KEY=
# 선택: Finnhub 가격/캘린더
FINNHUB_API_KEY=

# ─────────────────────────────────────────
# LangSmith / LangChain (선택 — observability)
# ─────────────────────────────────────────
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=disclosure-analysis
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=antelligen-backend
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─────────────────────────────────────────
# KRX (선택 — 외인/기관 수급 데이터)
# ─────────────────────────────────────────
# KRX_ID=
# KRX_PW=

# ─────────────────────────────────────────
# CORS / 프론트엔드 연결
# ─────────────────────────────────────────
# CORS_ALLOWED_FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────
# 모델 / 캐시 / 튜닝 파라미터 (선택, 모두 합리적 default)
# ─────────────────────────────────────────
# OPENAI_FINANCE_AGENT_MODEL=gpt-5-mini
# OPENAI_LEARNING_MODEL=gpt-5-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# FINANCE_RAG_TOP_K=3
# FINANCE_ANALYSIS_CACHE_TTL_SECONDS=3600
# SESSION_TTL_SECONDS=3600
# ANALYSIS_API_TIMEOUT_SECONDS=10.0

# ─────────────────────────────────────────
# History Agent (OKR 1·2·3 관련)
# ─────────────────────────────────────────
# HISTORY_TITLE_BATCH_SIZE=15
# HISTORY_TITLE_CONCURRENCY=10
# HISTORY_NEWS_SUMMARY_BATCH_SIZE=5
# HISTORY_TITLE_LLM_MODEL=gpt-5-mini
# HISTORY_CAUSALITY_PRE_DAYS=14
# HISTORY_CAUSALITY_POST_DAYS=3
# INDEX_CAUSALITY_LLM_ENABLED=false
# HISTORY_MACRO_REASON_CUTOFF=2024-08-01
# HISTORY_HOLDINGS_CONCURRENCY=3
# HISTORY_NEWS_TOP_N=10
# HISTORY_NEWS_PER_SOURCE_TIMEOUT_S=8.0
# HISTORY_NEWS_SCRAPE_ENABLED=false
# HISTORY_NEWS_KOREAN_SUMMARY_ENABLED=true

# ─────────────────────────────────────────
# OKR 3 다층 이상치 탐지 — robust σ 디버그
# ─────────────────────────────────────────
# off | stable | mad — KR4 측정 중 로컬에서 swap
# ANOMALY_ROBUST_SIGMA_METHOD=off

# ─────────────────────────────────────────
# 매크로 타임라인 / Importance / Event Impact
# ─────────────────────────────────────────
# MACRO_TIMELINE_TOP_N=30
# MACRO_IMPORTANCE_LLM_ENABLED=true
# MACRO_CACHE_TTL_SECONDS=86400
# ENABLE_US_TICKERS=false
# SEC_EDGAR_USER_AGENT=Antelligen research@example.com
# EVENT_IMPACT_IN_IMPORTANCE_PROMPT=true
# CAUSALITY_USE_CACHED_BARS=false

# ─────────────────────────────────────────
# Source Tier 가중치 (선택 실험)
# ─────────────────────────────────────────
# ENABLE_SOURCE_TIER_WEIGHTING=false
# TIER_MULTIPLIER_HIGH=1.0
# TIER_MULTIPLIER_MEDIUM=0.7
# TIER_MULTIPLIER_MEDIUM_LOW=0.5
# TIER_MULTIPLIER_LOW=0.3

# ─────────────────────────────────────────
# yfinance retry
# ─────────────────────────────────────────
# YFINANCE_RETRY_MAX_ATTEMPTS=3
# YFINANCE_RETRY_BASE_DELAY=1.0
